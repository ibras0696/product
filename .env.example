APP_ENVIRONMENT=development
IMAGE_TAG=local
HTTP_PORT=8080

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_PORT=5432

REDIS_PASSWORD=replace-with-a-long-random-password
REDIS_PORT=6379

RABBITMQ_USER=app
RABBITMQ_PASSWORD=replace-with-a-long-random-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
CELERY_CONCURRENCY=2
AUTH_SESSION_IDLE_DAYS=7
AUTH_SESSION_ABSOLUTE_DAYS=30
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
MEDIA_STORAGE_ROOT=/var/lib/product/media
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD_FILE=

DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
